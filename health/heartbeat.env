# Guidearr heartbeat config — copy to heartbeat.env and edit.
#   cp heartbeat.env.example heartbeat.env
# heartbeat.env is git-ignored / not overwritten on redeploy.

# Where the stack lives (must contain docker-compose.yml).
COMPOSE_DIR=/opt/Guidearr

# Compose invocation. Use "docker compose" (v2) or "docker-compose" (v1).
COMPOSE="docker compose"

# Services to verify are up/healthy.
SERVICES="db app web worker scheduler"

# Services the heartbeat is allowed to auto-restart. Remove "db" if you would
# rather be paged than have the DB restarted automatically.
RESTARTABLE="worker scheduler app db"

# --- Thresholds (alert-only for cpu/mem/disk) --------------------------------
LOAD_WARN_PER_CORE=2.0     # 1-min loadavg per CPU core
MEM_WARN_PCT=90            # host memory used %
DISK_WARN_PCT=90           # disk used % on COMPOSE_DIR

# --- Anti-spam ---------------------------------------------------------------
# Re-send an alert for the SAME issue at most once per this many seconds.
ALERT_COOLDOWN_SEC=14400   # 4 hours

# --- Email -------------------------------------------------------------------
# Recipient (defaults to ADMIN_EMAIL from the app if left unset).
MAIL_TO=admin@example.com
MAIL_FROM=guidearr-health@example.com

# SMTP via curl. Two common shapes:
#   Implicit TLS (port 465):  SMTP_URL=smtps://smtp.example.com:465   SMTP_STARTTLS=0
#   STARTTLS    (port 587):   SMTP_URL=smtp://smtp.example.com:587    SMTP_STARTTLS=1
# Leave SMTP_URL empty to fall back to the host `sendmail` if present.
SMTP_URL=smtps://smtp.example.com:465
SMTP_USER=alerts@example.com
SMTP_PASS=changeme
SMTP_STARTTLS=0

# --- State / log -------------------------------------------------------------
# STATE_DIR=/opt/Guidearr/health/state
# LOG_FILE=/opt/Guidearr/health/heartbeat.log
