services:
  app:
    build: .
    restart: unless-stopped
    volumes: [ "./:/var/www/html" ]
    depends_on:
      db:
        condition: service_healthy
  web:
    image: nginx:1.27-alpine
    restart: unless-stopped
    ports:
      - "7979:7979"            # direct TLS (existing)
      - "127.0.0.1:8080:8080"  # plain HTTP for the local proxy only — adjust the bind to your proxy's reach
    volumes:
      - ./:/var/www/html
      - ./docker/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./docker/nginx-logrotate.sh:/docker-entrypoint.d/99-nginx-logrotate.sh:ro
      - ./certs:/etc/ssl/tunarr:ro
    depends_on: [app]
  db:
    image: mysql:8.4
    environment:
      MYSQL_DATABASE: tunarr
      MYSQL_USER: tunarr
      MYSQL_PASSWORD: ${DB_PASSWORD}
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
    volumes: [ "dbdata:/var/lib/mysql" ]
    ports: [ "33060:3306" ]
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "--silent"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 40s
  mailpit:
    image: axllent/mailpit:latest
    restart: unless-stopped
    ports: [ "8025:8025" ]
  worker:
    build: .
    restart: unless-stopped
    user: www-data
    working_dir: /var/www/html
    command: php artisan feed:work --sleep=15
    volumes: [ "./:/var/www/html" ]
    depends_on:
      db:
        condition: service_healthy
  scheduler:
    build: .
    restart: unless-stopped
    user: www-data
    working_dir: /var/www/html
    command: php artisan schedule:work
    volumes: [ "./:/var/www/html" ]
    depends_on:
      db:
        condition: service_healthy
volumes:
  dbdata:
